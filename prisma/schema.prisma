// Rose Cafe — Full Database Schema
// QR Table Ordering System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── طاولات المقهى ───
model Table {
  id        Int      @id @default(autoincrement())
  number    Int      @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

// ─── تصنيفات القائمة ───
model Category {
  id          Int        @id @default(autoincrement())
  nameAr      String
  nameEn      String     @default("")
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       MenuItem[]
}

// ─── عناصر القائمة ───
model MenuItem {
  id           Int               @id @default(autoincrement())
  nameAr       String
  nameEn       String            @default("")
  descriptionAr String?
  descriptionEn String?
  price        Decimal           @db.Decimal(10, 2)
  image        String?
  isAvailable  Boolean           @default(true)
  sortOrder    Int               @default(0)
  categoryId   Int
  category     Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  optionGroups MenuOptionGroup[]
  orderItems   OrderItem[]
}

// ─── مجموعة خيارات (مثل: الحجم، السكر، الحليب) ───
model MenuOptionGroup {
  id          Int          @id @default(autoincrement())
  nameAr      String
  nameEn      String       @default("")
  isRequired  Boolean      @default(false)
  isMultiple  Boolean      @default(false)  // true = اختيار متعدد, false = اختيار واحد
  menuItemId  Int
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  options     MenuOption[]
}

// ─── خيار فردي (مثل: صغير، وسط، كبير) ───
model MenuOption {
  id               Int              @id @default(autoincrement())
  nameAr           String
  nameEn           String           @default("")
  extraPrice       Decimal          @default(0) @db.Decimal(10, 2)
  isDefault        Boolean          @default(false)
  isAvailable      Boolean          @default(true)
  optionGroupId    Int
  optionGroup      MenuOptionGroup  @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  sortOrder        Int              @default(0)
  orderItemOptions OrderItemOption[]
}

// ─── حالة الطلب ───
enum OrderStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

// ─── الطلبات ───
model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @unique @default(cuid())
  tableId        Int
  table          Table       @relation(fields: [tableId], references: [id])
  status         OrderStatus @default(NEW)
  notes          String?
  totalAmount    Decimal     @db.Decimal(10, 2)
  idempotencyKey String?     @unique
  statusChangedBy String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
}

// ─── عناصر الطلب (مع snapshot) ───
model OrderItem {
  id            Int               @id @default(autoincrement())
  orderId       Int
  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    Int
  menuItem      MenuItem          @relation(fields: [menuItemId], references: [id])
  quantity      Int               @default(1)
  unitPrice     Decimal           @db.Decimal(10, 2)   // snapshot السعر وقت الطلب
  itemNameAr    String            // snapshot الاسم وقت الطلب
  notes         String?
  options       OrderItemOption[]
}

// ─── خيارات عنصر الطلب (مع snapshot) ───
model OrderItemOption {
  id            Int        @id @default(autoincrement())
  orderItemId   Int
  orderItem     OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  menuOptionId  Int
  menuOption    MenuOption @relation(fields: [menuOptionId], references: [id])
  optionNameAr  String     // snapshot
  extraPrice    Decimal    @db.Decimal(10, 2) // snapshot
}

// ─── مستخدمي الأدمن ───
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
