// Rose Cafe — Full Database Schema (MongoDB Version)
// QR Table Ordering System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── طاولات المقهى ───
model Table {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  number    Int      @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

// ─── تصنيفات القائمة ───
model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  nameAr      String
  nameEn      String     @default("")
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       MenuItem[]
}

// ─── عناصر القائمة ───
model MenuItem {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  nameAr        String
  nameEn        String            @default("")
  descriptionAr String?
  descriptionEn String?
  price         Float
  image         String?
  isAvailable   Boolean           @default(true)
  sortOrder     Int               @default(0)
  categoryId    String            @db.ObjectId
  category      Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  optionGroups  MenuOptionGroup[]
  orderItems    OrderItem[]
}

// ─── مجموعة خيارات (مثل: الحجم، السكر، الحليب) ───
model MenuOptionGroup {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  nameAr      String
  nameEn      String       @default("")
  isRequired  Boolean      @default(false)
  isMultiple  Boolean      @default(false)  // true = اختيار متعدد, false = اختيار واحد
  menuItemId  String       @db.ObjectId
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  options     MenuOption[]
}

// ─── خيار فردي (مثل: صغير، وسط، كبير) ───
model MenuOption {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  nameAr           String
  nameEn           String            @default("")
  extraPrice       Float             @default(0)
  isDefault        Boolean           @default(false)
  isAvailable      Boolean           @default(true)
  optionGroupId    String            @db.ObjectId
  optionGroup      MenuOptionGroup   @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  sortOrder        Int               @default(0)
  orderItemOptions OrderItemOption[]
}

// ─── حالة الطلب ───
enum OrderStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

// ─── الطلبات ───
model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber     String      @unique @default(cuid())
  tableId         String      @db.ObjectId
  table           Table       @relation(fields: [tableId], references: [id])
  status          OrderStatus @default(NEW)
  notes           String?
  totalAmount     Float
  idempotencyKey  String?     @unique
  statusChangedBy String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

// ─── عناصر الطلب (مع snapshot) ───
model OrderItem {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String            @db.ObjectId
  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String            @db.ObjectId
  menuItem      MenuItem          @relation(fields: [menuItemId], references: [id])
  quantity      Int               @default(1)
  unitPrice     Float             // snapshot السعر وقت الطلب
  itemNameAr    String            // snapshot الاسم وقت الطلب
  notes         String?
  options       OrderItemOption[]
}

// ─── خيارات عنصر الطلب (مع snapshot) ───
model OrderItemOption {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId   String     @db.ObjectId
  orderItem     OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  menuOptionId  String     @db.ObjectId
  menuOption    MenuOption @relation(fields: [menuOptionId], references: [id])
  optionNameAr  String     // snapshot
  extraPrice    Float      // snapshot
}

// ─── مستخدمي الأدمن ───
model AdminUser {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  displayName  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
